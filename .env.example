# =========================================================
# G2_67_Jr — Environment template
# Copy to .env and fill real values. NEVER commit .env.
# =========================================================

# ---------- PostgreSQL ----------
POSTGRES_USER=gmrag
POSTGRES_PASSWORD=gmrag_change_me
POSTGRES_DB=gmrag
POSTGRES_PORT=5432
DATABASE_URL=postgres://gmrag:gmrag_change_me@postgres16:5432/gmrag
DATABASE_URL_ADMIN=postgres://postgres:postgres_change_me@postgres16:5432/gmrag

# ---------- Qdrant ----------
QDRANT_URL=http://qdrant:6334
QDRANT_API_KEY=
QDRANT_COLLECTION_DEFAULT=gmrag_chunks

# ---------- MinIO / S3 ----------
S3_ENDPOINT=http://minio:9000
S3_PUBLIC_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=gmrag_minio
S3_SECRET_KEY=gmrag_minio_change_me
S3_BUCKET=gmrag-uploads
S3_FORCE_PATH_STYLE=true

# ---------- Redis ----------
REDIS_URL=redis://redis:6379/0
REDIS_PORT=6379

# ---------- OpenFGA authorization ----------
# Bootstrap ordering on a FRESH clone / reused pgdata volume:
#   1. docker compose ... up -d postgres16          # wait for healthy
#   2. pwsh ./scripts/ensure-openfga-db.ps1          # idempotent CREATE
#                                                    #   DATABASE openfga
#                                                    #   (init.sql only
#                                                    #   runs on first
#                                                    #   volume init!)
#   3. docker compose ... up -d openfga-migrate openfga
#   4. pwsh ./scripts/openfga-bootstrap.ps1         # prints IDs below
OPENFGA_HTTP_PORT=8089
OPENFGA_DATASTORE_ENGINE=postgres
OPENFGA_DATASTORE_URI=postgres://gmrag:gmrag_change_me@postgres16:5432/openfga?sslmode=disable
OPENFGA_API_URL=http://localhost:8089
OPENFGA_INTERNAL_API_URL=http://openfga:8080
OPENFGA_API_TOKEN=gmrag_openfga_dev_change_me
OPENFGA_STORE_NAME=gmrag-v2
# OPENFGA_STORE_ID and OPENFGA_AUTHORIZATION_MODEL_ID are produced by the
# bootstrap script (./scripts/openfga-bootstrap.ps1). Run it after OpenFGA
# starts, then paste the printed IDs below — the API fails to boot without them.
OPENFGA_STORE_ID=replace-with-openfga-store-id
OPENFGA_AUTHORIZATION_MODEL_ID=replace-with-openfga-model-id
OPENFGA_REQUEST_TIMEOUT_MS=1500
OPENFGA_HIGHER_CONSISTENCY_WINDOW_SECS=5

# ---------- Ollama ----------
# Ollama ships empty — pull models BEFORE indexing/chat, otherwise the
# worker embedding call and chat/graph LLM calls 404. One-shot run:
#   pwsh ./scripts/setup-ollama.ps1
# (pulls OLLAMA_EMBED_MODEL always; pulls OLLAMA_LLM_MODEL only when
# DEEPSEEK_API_KEY is empty. If you set DEEPSEEK_API_KEY, chat+graph go
# to DeepSeek and only the embed model is required locally.)
OLLAMA_HOST=http://ollama:11434
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_LLM_MODEL=llama3.1:8b
OLLAMA_KEEP_ALIVE=30m

# ---------- DeepSeek (optional remote LLM) ----------
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_TIMEOUT_S=60
GMRAG_TENANT_KEY_ENCRYPTION_KEY=

# ---------- Keycloak / OIDC ----------
# After bringing up keycloak, bootstrap the realm + clients:
#   docker cp infra/keycloak/bootstrap.sh gmrag-keycloak:/tmp/bootstrap.sh
#   docker exec -e KEYCLOAK_ADMIN=admin -e KEYCLOAK_ADMIN_PASSWORD=<pw> \
#     gmrag-keycloak bash /tmp/bootstrap.sh
# bootstrap.sh now creates an `aud=gmrag-backend` audience mapper on the
# backend client automatically — without it, service-account tokens are
# rejected with InvalidAudience. (Override audience via BACKEND_AUDIENCE.)
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin_change_me
KEYCLOAK_REALM=gmrag
KEYCLOAK_ISSUER=http://keycloak:8080/realms/gmrag
KEYCLOAK_ISSUER_PUBLIC=http://localhost:8080/realms/gmrag
# Public issuer accepted in browser-minted tokens. The API also accepts the
# internal KEYCLOAK_ISSUER value for service/container-side tokens.
KEYCLOAK_ISSUER_VERIFY=http://localhost:8080/realms/gmrag
KEYCLOAK_CLIENT_ID=gmrag-backend
KEYCLOAK_CLIENT_SECRET=gmrag_backend_change_me
KEYCLOAK_FRONTEND_CLIENT_ID=gmrag-frontend

# ---------- GMRAG app ----------
GMRAG_RUST_LOG=info,gmrag_api=debug,gmrag_worker=debug,gmrag_core=debug
GMRAG_HTTP_BIND=0.0.0.0:8080
# Phase 1: number of ingest jobs the worker processes CONCURRENTLY. The worker
# BRPOP-pops jobs in a single producer loop and runs up to this many
# `process_job_with_retry` handlers at once (semaphore-gated). Honoured at
# runtime by gmrag_worker::run_dispatcher. Default 4; bad/zero/empty values
# fall back to the default silently (with a warning) instead of crashing.
GMRAG_WORKER_CONCURRENCY=4
GMRAG_TENANT_HEADER=X-Tenant-ID
GMRAG_DEFAULT_TENANT=00000000-0000-0000-0000-000000000000

# ---------- T84D backend tuning ----------
# Postgres pool ceiling (admin + RLS-enforced app pool). Default 10.
DATABASE_MAX_CONNECTIONS=10
# Feature-flag for the OCR fallback path. Off by default so the Docker
# image never bakes native libpdfium in. Flip on AND add the
# `ocr-pdfium` Cargo feature once a libpdfium image is available.
GMRAG_OCR_ENABLED=false
# How often the worker's outbox relay polls `ingest_outbox` (seconds).
GMRAG_OUTBOX_POLL_INTERVAL_SECS=3
# How often the worker's job-recovery sweeper scans `ingest_jobs` (seconds).
GMRAG_SWEEP_INTERVAL_SECS=60
# Past chat messages threaded into the LLM context per turn.
GMRAG_CHAT_HISTORY_LIMIT=10

# ---------- Phase 4 rate limiting / observability ----------
GMRAG_RATELIMIT_ENABLED=true
GMRAG_RATELIMIT_AUTH_PER_MIN=10
GMRAG_RATELIMIT_JOB_CREATE_PER_MIN=20
GMRAG_RATELIMIT_CHAT_CREATE_PER_MIN=30
GMRAG_RATELIMIT_CHAT_CONCURRENT_PER_TENANT=50
GMRAG_RATELIMIT_GENERAL_PER_MIN=300
GMRAG_WORKER_METRICS_BIND=0.0.0.0:9091

# ---------- Phase 0 retention (TASK-P0-04) ----------
# Bounded periodic retention task run by the worker (admin_pool,
# cross-tenant maintenance). Deletes dispatched ingest_outbox rows,
# usage_events, and audit_log older than their configured windows in
# bounded batches. Defaults: 30 / 90 / 365 days, once per day, 1000 rows.
GMRAG_RETENTION_INTERVAL_SECS=86400
GMRAG_OUTBOX_RETENTION_DAYS=30
GMRAG_USAGE_RETENTION_DAYS=90
GMRAG_AUDIT_RETENTION_DAYS=365
GMRAG_RETENTION_BATCH_SIZE=1000

# ---------- Frontend ----------
NEXT_PUBLIC_API_BASE_URL=http://localhost:8088
NEXT_PUBLIC_KEYCLOAK_URL=http://localhost:8080
NEXT_PUBLIC_KEYCLOAK_REALM=gmrag
NEXT_PUBLIC_KEYCLOAK_CLIENT_ID=gmrag-frontend
NEXT_PUBLIC_TENANT_HEADER=X-Tenant-ID

# ---------- NextAuth (Auth.js v5) ----------
# Server-only. Generate with: openssl rand -base64 32
AUTH_SECRET=
AUTH_TRUST_HOST=true
# Keycloak client secret for the gmrag-frontend OIDC client (server-only).
# Leave empty if the client is public (PKCE).
KEYCLOAK_FRONTEND_CLIENT_SECRET=

# ---------- CORS ----------
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080
CORS_ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Authorization,Content-Type,X-Tenant-ID,X-Request-ID
CORS_ALLOW_CREDENTIALS=true
